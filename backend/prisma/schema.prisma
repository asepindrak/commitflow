// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model aiToolCache {
  id         String   @id @default(cuid())
  toolName   String
  parameters Json?
  result     Json? // Use Json instead of String for JSON data
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("ai_tool_cache")
}

model dataCache {
  id         String   @id @default(cuid())
  dataName   String
  parameters Json?
  result     Json? // Use Json instead of String for JSON data
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("data_cache")
}

model chatMessage {
  id        String   @id @default(cuid())
  userId    String
  content   String   @db.Text
  role      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("chat_message")
}

model User {
  id                    String       @id @default(cuid())
  email                 String?      @unique
  phone                 String?
  name                  String?
  photo                 String?
  role                  Role?        @default(USER)
  password              String? // kalau pake password
  session_token         String?      @unique
  refreshTokenHash      String? // simpan hash dari refresh token
  refreshTokenExpiresAt DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  members               TeamMember[] @relation("UserMembers")
}

model TeamMember {
  id          String  @id @default(uuid())
  clientId    String? @unique
  userId      String
  workspaceId String

  name  String
  role  String?
  email String?
  photo String?
  phone String?

  isTrash Boolean @default(false)
  isAdmin Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime?

  // 🔗 RELATIONS (HARUS SESUAI NAMA)
  assignedTasks Task[] @relation("TaskAssignee")

  taskAssignees TaskAssignee[]

  // FK
  workspace Workspace? @relation("WorkspaceMembers", fields: [workspaceId], references: [id])
  user      User?      @relation("UserMembers", fields: [userId], references: [id])
}

model Workspace {
  id          String       @id @default(uuid())
  clientId    String?      @unique
  name        String
  description String?
  isTrash     Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime?
  projects    Project[]    @relation("WorkspaceProjects")
  members     TeamMember[] @relation("WorkspaceMembers")
}

model Project {
  id          String     @id @default(uuid())
  workspaceId String?
  clientId    String?    @unique
  name        String
  description String?
  isTrash     Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime?
  workspace   Workspace? @relation("WorkspaceProjects", fields: [workspaceId], references: [id])
  tasks       Task[]     @relation("ProjectTasks")
}

model Task {
  id          String  @id @default(uuid())
  title       String
  description String?
  status      String  @default("todo")

  projectId String?
  project   Project? @relation("ProjectTasks", fields: [projectId], references: [id])

  // 👤 ASSIGNEE (legacy single)
  assigneeId String?
  assignee   TeamMember? @relation("TaskAssignee", fields: [assigneeId], references: [id])

  // 👥 MULTI ASSIGNEE
  taskAssignees TaskAssignee[]

  startDate  String?
  dueDate    String?
  finishDate DateTime?
  priority   String?
  labels     Json?     // Array of { name: string, color: string }
  sprintId   String?
  dependencies Json?   // Array of { taskId: string, type: "blocked_by" | "blocks" }
  timeEntries  Json?   // Array of { memberId, memberName, start, end?, duration? }
  recurrence   Json?   // { pattern: "daily"|"weekly"|"monthly"|"custom", interval?: number, daysOfWeek?: number[], nextDue?: string }

  comments Comment[] @relation("TaskComments")

  clientId String? @unique

  createdAt DateTime  @default(now())
  updatedAt DateTime?

  // 👤 AUDIT FIELDS (Team Member ID)
  createdById String?
  updatedById String?

  isTrash Boolean @default(false)
}

model TaskAssignee {
  id       String @id @default(uuid())
  taskId   String
  memberId String

  assignedAt DateTime @default(now())

  task   Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  member TeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([taskId, memberId])
}

model Comment {
  id          String    @id @default(uuid())
  taskId      String
  task        Task      @relation("TaskComments", fields: [taskId], references: [id])
  memberId    String?
  author      String
  body        String
  attachments Json? // optional JSON array of attachments metadata
  isTrash     Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime?
}

model Invite {
  id          String    @id @default(uuid())
  workspaceId String
  email       String
  invitedBy   String
  isInvited   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime?
}

model GroupChatMessage {
  id          String   @id @default(cuid())
  workspaceId String
  memberId    String
  memberName  String
  memberPhoto String?
  content     String   @db.Text
  attachments Json?
  replyTo     Json?
  isPinned    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([workspaceId, createdAt])
  @@map("group_chat_message")
}

model ActivityLog {
  id          String   @id @default(cuid())
  workspaceId String
  memberId    String?
  memberName  String?
  action      String   // e.g. "task.created", "task.status_changed", "project.created", "member.added"
  entity      String?  // e.g. "task", "project", "member", "comment"
  entityId    String?
  entityName  String?  // human-readable, e.g. task title or project name
  meta        Json?    // extra details, e.g. { from: "todo", to: "done" }
  createdAt   DateTime @default(now())

  @@index([workspaceId, createdAt])
  @@map("activity_log")
}

model Sprint {
  id          String    @id @default(uuid())
  workspaceId String
  name        String
  description String?
  status      String    @default("planning") // planning, active, completed
  startDate   String?
  endDate     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime?

  @@index([workspaceId])
  @@map("sprint")
}

model DirectMessage {
  id          String   @id @default(cuid())
  workspaceId String
  senderId    String
  senderName  String
  senderPhoto String?
  receiverId  String
  content     String   @db.Text
  attachments Json?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([workspaceId, senderId, receiverId])
  @@index([workspaceId, receiverId, isRead])
  @@map("direct_message")
}

enum Role {
  USER
  ADMIN
}
